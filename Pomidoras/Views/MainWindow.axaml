<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pomidoras.Controls"
    xmlns:viewModels="using:Pomidoras.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:markup="clr-namespace:Pomidoras.Markup"
    mc:Ignorable="d"
    d:DesignWidth="150"
    d:DesignHeight="90"
    d:DataContext="{markup:DesignLocator {x:Type viewModels:MainWindowViewModel}}"
    x:Class="Pomidoras.Views.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
    Name="Main"
    Icon="/Assets/avalonia-logo.ico"
    Title="Pomidoras"
    Width="150"
    Height="90"
    ExtendClientAreaToDecorationsHint="True"
    CanResize="False">

    <Panel
        Name="ViewRoot">
        <StackPanel>
            <controls:TimerModeBarControl Height="25"
                                          DataContext="{Binding .}" />
            <controls:TimerDisplayBarControl Height="30"
                                             Margin="0,2,0,1"
                                             DataContext="{Binding .}" />
            <controls:TimerPlaybackBarControl DataContext="{Binding .}" />
        </StackPanel>
    </Panel>
</Window>