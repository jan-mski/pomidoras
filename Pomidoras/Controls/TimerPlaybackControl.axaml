<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Pomidoras.ViewModels"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="Pomidoras.Controls.TimerPlaybackControl"
    x:DataType="viewModels:MainWindowViewModel">
    <Panel>
        <Button
            Name="Start"
            Classes="timer-playback-control"
            IsVisible="{Binding !IsRunning}"
            Command="{Binding StartTimerCommand}">
            <Panel>
                <PathIcon
                    Classes="timer-playback-control-icon"
                    Data="{StaticResource PlayRegular}" />
            </Panel>
        </Button>
        <Button
            Name="Stop"
            Classes="timer-playback-control"
            IsVisible="{Binding IsRunning}"
            Command="{Binding StopTimerCommand}">
            <Panel>
                <PathIcon
                    Classes="timer-playback-control-icon"
                    Data="{StaticResource StopRegular}" />
            </Panel>
        </Button>
    </Panel>
</UserControl>