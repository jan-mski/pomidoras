<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Pomidoras.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Pomidoras.Controls.SettingsPaneControl"
             x:DataType="viewModels:MainWindowViewModel">
    <StackPanel
        Spacing="2"
        Orientation="Vertical">
        <StackPanel.Styles>
            <Style Selector="StackPanel > Button#CloseSettingsPane">
                <Setter Property="Width" Value="14" />
                <Setter Property="VerticalAlignment" Value="Top" />

                <Style Selector="^ PathIcon">
                    <Setter Property="Height" Value="10" />
                </Style>
            </Style>

            <Style Selector="StackPanel > Button.settingToggle">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Width" Value="110" />
                <Setter Property="Padding" Value="0" />

                <Style Selector="^ PathIcon">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Height" Value="8" />
                </Style>

                <Style Selector="^ TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="FontSize" Value="10" />
                </Style>
            </Style>
        </StackPanel.Styles>

        <Button
            Name="CloseSettingsPane"
            Command="{Binding ToggleSettingsPaneCommand}">
            <PathIcon
                Data="{StaticResource FluentUi-ChevronRight-Filled-16}" />
        </Button>

        <Button
            Name="AlwaysOnTopToggle"
            Classes="settingToggle"
            Command="{Binding ToggleAlwaysOnTopCommand}">
            <StackPanel Orientation="Horizontal">
                <PathIcon
                    IsVisible="{Binding AlwaysOnTop}"
                    Data="{StaticResource FluentUi-Pin-Filled-16}" />
                <PathIcon
                    IsVisible="{Binding !AlwaysOnTop}"
                    Data="{StaticResource FluentUi-PinOff-Filled-16}" />
                <TextBlock>
                    Always On Top
                </TextBlock>
            </StackPanel>
        </Button>

        <Button
            Name="ContinuousModeToggle"
            Classes="settingToggle"
            Command="{Binding TimerViewModel.ToggleContinuousModeCommand}">
            <StackPanel Orientation="Horizontal">
                <PathIcon
                    IsVisible="{Binding TimerViewModel.ContinuousModeEnabled}"
                    Data="{StaticResource FluentUi-ArrowRepeatAll-Filled-16}" />
                <PathIcon
                    IsVisible="{Binding !TimerViewModel.ContinuousModeEnabled}"
                    Data="{StaticResource FluentUi-ArrowRepeatAllOff-Filled-16}" />
                <TextBlock>
                    Continuous mode
                </TextBlock>
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>