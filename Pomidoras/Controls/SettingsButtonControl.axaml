<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Pomidoras.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Pomidoras.Controls.SettingsButtonControl"
             x:DataType="viewModels:MainWindowViewModel">
    <Panel>
        <Panel.Styles>
            <Style Selector="Panel > Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Height" Value="16" />
                <Setter Property="Width" Value="20" />
                <Setter Property="HorizontalAlignment" Value="Right" />

                <Style Selector="^ > PathIcon">
                    <Setter Property="Height" Value="8" />
                </Style>
            </Style>
        </Panel.Styles>

        <Button Name="Settings"
                Command="{Binding ToggleSettingsPaneCommand}">
            <PathIcon Data="{StaticResource FluentUi-Settings-Filled-16}" />
        </Button>
    </Panel>
</UserControl>