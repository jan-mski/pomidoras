<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Pomidoras.ViewModels" mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450" x:Class="Pomidoras.Controls.TimerPlaybackBarControl"
             x:DataType="viewModels:MainWindowViewModel">
    <Panel>
        <Panel.Styles>
            <Style Selector="Panel > Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Height" Value="22" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Top" />

                <Style Selector="^ > PathIcon">
                    <Setter Property="Height" Value="10" />
                </Style>
            </Style>
        </Panel.Styles>

        <Button Name="Start"
                IsVisible="{Binding !IsRunning}"
                Command="{Binding StartTimerCommand}">
            <PathIcon Data="{StaticResource FluentUi-Play-Regular-16}" />
        </Button>
        <Button Name="Stop"
                IsVisible="{Binding IsRunning}"
                Command="{Binding StopTimerCommand}">
            <PathIcon Data="{StaticResource FluentUi-Stop-Regular-16}" />
        </Button>
    </Panel>
</UserControl>