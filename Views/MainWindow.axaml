<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Pomidoras.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="120"
    d:DesignHeight="100"
    x:Class="Pomidoras.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    Title="Pomidoras"
    Width="120"
    Height="100">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid
        ShowGridLines="False"
        Margin="5"
        RowDefinitions="0.5*, *, *"
        ColumnDefinitions="*, 2*, *">
        <TextBlock
            Name="Timer"
            Grid.Row="1"
            Grid.Column="1"
            FontSize="16"
            Text="{Binding TimerViewModel.Remaining, StringFormat='mm\\:ss'}"
            VerticalAlignment="Center"
            HorizontalAlignment="Center" />
        <Button
            Background="Black"
            Name="StartStop"
            Grid.Row="2"
            Grid.Column="1"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Command="{Binding StartStopCommand}">
            <Panel>
                <PathIcon
                    IsVisible="{Binding !TimerViewModel.IsRunning}"
                    Data="{StaticResource PlayRegular}"
                    Height="10" />
                <PathIcon
                    IsVisible="{Binding TimerViewModel.IsRunning}"
                    Data="{StaticResource StopRegular}"
                    Height="10" />
            </Panel>
        </Button>
    </Grid>

</Window>